# Donia backend — copy to .env and fill in
NODE_ENV=development
PORT=3000

# Database (Railway provides this in prod automatically)
DATABASE_URL="postgresql://user:pass@localhost:5432/donia?schema=public"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN=30d
OTP_CODE_LENGTH=6
OTP_TTL_MINUTES=10

# Business model
COMMISSION_RATE=0.05            # 5% commission on card redemption
REFERRAL_RATE=0.01              # 1% on filleul transactions
SUPPORTED_COUNTRIES="BJ,CI,SN,TG,BF,ML,NE,GN,GH,CM"

# Cards
CARD_CODE_PREFIX=DON-2026

# FedaPay (payments)
FEDAPAY_PUBLIC_KEY=
FEDAPAY_SECRET_KEY=
FEDAPAY_ENV=sandbox             # sandbox | live
FEDAPAY_WEBHOOK_SECRET=

# Resend (transactional emails)
RESEND_API_KEY=
EMAIL_FROM="Donia <hello@donia.app>"

# WhatsApp Cloud API (or alternative provider for OTP via WA)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# SMS (Twilio or other)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# CORS
CORS_ORIGINS="http://localhost:8081,http://localhost:5173,https://admin.donia.app"
